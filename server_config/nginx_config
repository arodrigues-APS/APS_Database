# Apache Superset - data.aps.ee.ethz.ch
server {
    listen 80;
    server_name data.aps.ee.ethz.ch www.data.aps.ee.ethz.ch;

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 120s;
    }
}

# Flask raw data app - rawdata.aps.ee.ethz.ch
server {
    listen 80;
    server_name rawdata.aps.ee.ethz.ch www.rawdata.aps.ee.ethz.ch;

    auth_basic "APS Database Access - Ask Helton or Ulrike for the password.";
    auth_basic_user_file /etc/apache2/.htpasswd;

    root /data/www/;

    location / {
        include uwsgi_params;
        uwsgi_pass unix:///tmp/server.sock;
    }
}
