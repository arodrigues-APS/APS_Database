# Apache Superset - data.aps.ee.ethz.ch
# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name data.aps.ee.ethz.ch;

    return 301 https://$host$request_uri;
}

# HTTPS server block
server {
    listen 443 ssl;
    server_name data.aps.ee.ethz.ch;

    ssl_certificate /etc/ssl/letsencrypt/ecc/data.aps.ee.ethz.ch.crt;
    ssl_certificate_key /etc/ssl/letsencrypt/ecc/data.aps.ee.ethz.ch.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    auth_basic "APS Database Access - Ask Helton or Ulrike for the password.";
    auth_basic_user_file /etc/apache2/.htpasswd;

    location = / {
        return 302 https://data.aps.ee.ethz.ch/dashboard/list/;
    }

    # Self-contained interactive APS analysis tools. Keep this exact file
    # route ahead of the Superset catch-all so it stays on the authenticated
    # data.aps.ee.ethz.ch origin without requiring another application server.
    location = /tools/damage-signature-3d {
        return 302 /tools/damage-signature-3d/;
    }

    location = /tools/damage-signature-3d/ {
        alias /data/www/tools/damage-signature-3d/index.html;
        default_type text/html;
        add_header Cache-Control "no-cache";
        add_header X-Content-Type-Options "nosniff" always;
    }

    location = /tools/sc-irrad-equivalence-3d {
        return 302 /tools/sc-irrad-equivalence-3d/;
    }

    location = /tools/sc-irrad-equivalence-3d/ {
        alias /data/www/tools/sc-irrad-equivalence-3d/index.html;
        default_type text/html;
        add_header Cache-Control "no-cache";
        add_header X-Content-Type-Options "nosniff" always;
    }

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 120s;
    }
}

# Flask raw data app - rawdata.aps.ee.ethz.ch
# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name rawdata.aps.ee.ethz.ch;

    return 301 https://$host$request_uri;
}

# HTTPS server block
server {
    listen 443 ssl;
    server_name rawdata.aps.ee.ethz.ch;

    ssl_certificate /etc/ssl/letsencrypt/ecc/rawdata.aps.ee.ethz.ch.crt;
    ssl_certificate_key /etc/ssl/letsencrypt/ecc/rawdata.aps.ee.ethz.ch.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    auth_basic "APS Database Access - Ask Helton or Ulrike for the password.";
    auth_basic_user_file /etc/apache2/.htpasswd;

    root /data/www/;

    location / {
        include uwsgi_params;
        uwsgi_pass unix:///tmp/server.sock;
    }
}
