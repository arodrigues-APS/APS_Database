# APS service environment contract.
# Copy to /etc/aps/aps.env, replace every change-me value, then set mode 0600.

APS_PROFILE=production

APS_DB_HOST=127.0.0.1
APS_DB_PORT=5435
APS_DB_NAME=mosfets
APS_DB_USER=postgres
APS_DB_PASSWORD=change-me

APS_SUPERSET_URL=http://127.0.0.1:8088
APS_SUPERSET_USER=admin
APS_SUPERSET_PASS=change-me
APS_SUPERSET_CONNECT_TIMEOUT_SECONDS=5
APS_SUPERSET_READ_TIMEOUT_SECONDS=60

APS_FLASK_SECRET_KEY=change-me

APS_DATA_ROOT=/data/aps
APS_NAS_ROOT=/data/nas
# Optional per-ingestion overrides. APS_SC_ROOTS uses the platform path separator.
# APS_PRISTINE_ROOT=/data/aps/Measurements/Pristine
# APS_IRRADIATION_ROOT=/data/aps/Measurements/Irradiation
# APS_AVALANCHE_ROOT=/data/nas/Avalanche
# APS_SC_ROOTS=/data/nas/Short Circuit Measurements/source-a:/data/nas/Short Circuit Measurements/source-b

APS_ENABLE_LEGACY_CV_DPT=0
APS_UPDATE_INFRASTRUCTURE=0
APS_DOCKER_IMAGE_PRUNE=1
APS_BACKUP_RETENTION_DAYS=14
APS_LOG_RETENTION_DAYS=30
APS_WEB_TOOLS_DIR=/data/www/tools

# Optional local dashboard artifact export; this is separate from Superset HTTP updates.
APS_DASHBOARD_EXPORT=0
# APS_DASHBOARD_EXPORT_DIR=/opt/aps_database/APS_Database/out/superset_charts
APS_DASHBOARD_EXPORT_STRICT=0
