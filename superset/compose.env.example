# Superset Compose environment contract.
# Copy to superset/.env, replace every change-me value, and set mode 0600.

POSTGRES_USER=superset
POSTGRES_PASSWORD=change-me
POSTGRES_DB=superset

DATABASE_DIALECT=postgresql
DATABASE_USER=superset
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DB=superset

EXAMPLES_USER=superset
EXAMPLES_PASSWORD=change-me
EXAMPLES_HOST=db
EXAMPLES_PORT=5432
EXAMPLES_DB=superset

SUPERSET_SECRET_KEY=change-me
# One-time rotation only; remove immediately after re-encrypting metadata.
# SUPERSET_PREVIOUS_SECRET_KEY=old-key

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CELERY_DB=0
REDIS_RESULTS_DB=1

# APS data database container. Keep its host publication loopback-only unless
# a separately documented firewall/remote-access policy requires otherwise.
APS_DATA_DB_USER=postgres
APS_DATA_DB_PASSWORD=change-me
APS_DATA_DB_NAME=mosfets
