# APS Database — environment variables
#
# Copy to `.env` (gitignored) for local reference, but note: nothing loads a
# .env file automatically today. Variables are read from the process
# environment at import time (data_processing_scripts/db_config.py). To set
# them for the deployed services, use `Environment=` /or/ `EnvironmentFile=`
# entries in server_config/*.service, or export them in the shell before
# running scripts.
#
# Every variable has a code default matching the historical deployment, so an
# empty environment still works on the lab server. Override for any other
# machine — and treat the passwords below as placeholders, never real values.

# ── PostgreSQL (mosfets database; docker container "postgresqlv2") ──────────
APS_DB_HOST=localhost
APS_DB_PORT=5435
APS_DB_NAME=mosfets
APS_DB_USER=postgres
APS_DB_PASSWORD=change-me

# ── Superset API (dashboard builders) ───────────────────────────────────────
APS_SUPERSET_URL=http://localhost:8088
APS_SUPERSET_USER=admin
APS_SUPERSET_PASS=change-me

# ── Data locations ──────────────────────────────────────────────────────────
# Root of the measurement data tree scanned by ingestion.
APS_DATA_ROOT=/home/arodrigues/APS_Database
# NAS common-files mount (logbooks, campaign spreadsheets).
APS_NAS_ROOT=/home/arodrigues/NAS/Common_Files

# ── Flask server (server.py) ────────────────────────────────────────────────
# Session-signing key; server.py falls back to a committed default if unset.
SECRET_KEY=change-me

# ── Nightly pipeline (scripts/nightly_update_and_ingest.sh) ─────────────────
APS_BACKUP_RETENTION_DAYS=14
APS_LOG_RETENTION_DAYS=30
APS_DOCKER_IMAGE_PRUNE=1

# ── Deploy (scripts/deploy_to_opt.sh) ───────────────────────────────────────
APS_DEPLOY_TARGET=/opt/aps_database/APS_Database
